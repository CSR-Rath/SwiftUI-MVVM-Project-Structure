<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    
    <!-- ================================================= -->
    <!-- Status Bar Configuration                          -->
    <!-- Control status bar appearance globally by the app -->
    <!-- ================================================= -->
    
    <key>UIViewControllerBasedStatusBarAppearance</key>
    <false/>
    
    
    <!-- ================================================= -->
    <!-- Privacy Permissions                               -->
    <!-- These descriptions appear in the system permission -->
    <!-- dialog when accessing device resources             -->
    <!-- ================================================= -->
    
    <key>NSPhotoLibraryUsageDescription</key>
    <string>This app needs access to photos to upload QR code images.</string>

    <key>NSCameraUsageDescription</key>
    <string>This app uses the camera to scan QR codes.</string>
    
    
    <!-- ================================================= -->
    <!-- Environment Configuration                         -->
    <!-- Values injected from Build Settings / xcconfig    -->
    <!-- ================================================= -->
    
    <key>API_KEY</key>
    <string>$(API_KEY)</string>

    <key>APP_ICON</key>
    <string>$(APP_ICON)</string>

    <key>BASE_URL</key>
    <string>$(BASE_URL)</string>

    <key>PRODUCT_BUNDLE_IDENTIFIER</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    
    
    <!-- ================================================= -->
    <!-- Alternate App Icons                               -->
    <!-- Support dynamic app icon switching                -->
    <!-- ================================================= -->
    
    <key>CFBundleIcons</key>
    <dict>
        <key>CFBundleAlternateIcons</key>
        <dict>
            <key>AppIcon1</key>
            <dict>
                <key>CFBundleIconFiles</key>
                <array>
                    <string>AppIcon1</string>
                </array>
            </dict>
            <key>AppIcon2</key>
            <dict>
                <key>CFBundleIconFiles</key>
                <array>
                    <string>AppIcon2</string>
                </array>
            </dict>
            <key>AppIcon3</key>
            <dict>
                <key>CFBundleIconFiles</key>
                <array>
                    <string>AppIcon3</string>
                </array>
            </dict>
        </dict>
    </dict>
    
    
    <!-- ================================================= -->
    <!-- Deep Link Configuration                           -->
    <!-- Allows the app to be opened via custom URL scheme -->
    <!-- Example: sophearathdeeplinkapp://                 -->
    <!-- ================================================= -->
    
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleTypeRole</key>
            <string>Editor</string>
            <key>CFBundleURLName</key>
            <string>com.sophearath.core</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>sophearathdeeplinkapp</string>
            </array>
        </dict>
    </array>
    
    
    <!-- ================================================= -->
    <!-- Firebase Configuration                            -->
    <!-- Disable automatic AppDelegate method swizzling    -->
    <!-- Useful when manually handling notifications       -->
    <!-- ================================================= -->
    
    <key>FirebaseAppDelegateProxyEnabled</key>
    <false/>
    
    
    <!-- ================================================= -->
    <!-- Custom Fonts                                      -->
    <!-- Register fonts bundled with the application       -->
    <!-- ================================================= -->
    
    <key>UIAppFonts</key>
    <array>
        <string>NotoSansKhmer-Regular.ttf</string>
        <string>NotoSansKhmer-Medium.ttf</string>
        <string>NotoSansKhmer-Bold.ttf</string>
        <string>Roboto-Regular.ttf</string>
        <string>Roboto-Bold.ttf</string>
        <string>Roboto-Medium.ttf</string>
    </array>

</dict>
</plist>
